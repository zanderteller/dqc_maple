</Group><CodeEditor-ExecGroup view="presentation" labelreference="L144" drawlabel="true" applyint="true" applyrational="true" display="code"><EC-CodeEditor id="CodeEditRegion0" expanded="true" visible="true" pixel-width="500" pixel-height="200" code-language="text/maple" autofit="true" wrapping="true" show-border="true" code-line-numbers="true">CoreDQC := module()


option package;
description &quot;main package for using DQC in Maple, including a DQC class&quot;;


# This package is the new (May 2021, updated Sep 2021) main package for DQC in Maple.  It includes a 'DQC' class whose instances store various parameters
# and intermediate results (sigma, operators, etc.).


uses StringTools, ArrayTools, LinearAlgebra, Statistics, RandomTools, combinat, plots;


# these are references to external dynamic-library compiled code (see ModuleLoad below)
local L2NormRowsC, ChooseBasisByDistanceC, BuildOverlapsC, MakeOperatorsC, BuildFramesAutoC;
local AddSecondaryC, ClearSecondariesC, ListSecondariesC, SecondaryCountC;


# define external functions (in our compiled dynamic-library code)
local ModuleLoad := proc()
	local lib_ext, lib_path;

	### load dynamic-library functions
	if Search(&quot;WINDOWS&quot;, kernelopts(system)) &gt; 0 then
		lib_ext := &quot;dll&quot;;
	elif Search(&quot;APPLE&quot;, kernelopts(system)) &gt; 0 then
		lib_ext := &quot;dylib&quot;;
	else
		error &quot;DQC module can only load dynamic library for Windows and Apple OS -- not yet supported for OS '%1'&quot;, kernelopts(system);
	end if; # OS is Windows, Apple, or other

	lib_path := JoinPath([kernelopts(homedir), &quot;maple&quot;, &quot;toolbox&quot;, &quot;CoreDQC&quot;, &quot;bin&quot;, sprintf(&quot;dqc_maple.%s&quot;, lib_ext)]);

	# define the external functions
	L2NormRowsC := define_external('L2NormRowsC', 'LIB'=lib_path, 'mat'::ARRAY(float[8]), 'num_rows'::integer[4], 'num_cols'::integer[4],
	                               'mat_out'::ARRAY(float[8]));
	ChooseBasisByDistanceC := define_external('ChooseBasisByDistanceC', 'LIB'=lib_path, 'rows'::ARRAY(float[8]), 'num_rows'::integer[4],
	                                          'num_cols'::integer[4], 'basis_size'::integer[4], 'basis_row_nums'::ARRAY(integer[4]),
	                                          'first_basis_row_num'::integer[4]);
	BuildOverlapsC:=define_external('BuildOverlapsC', 'LIB'=lib_path, 'sigma'::float[8], 'basis_rows'::ARRAY(float[8]), 'other_rows'::ARRAY(float[8]),
	                                'num_basis_rows'::integer[4], 'num_other_rows'::integer[4], 'num_cols'::integer[4], 'overlaps'::ARRAY(float[8]));
	MakeOperatorsC := define_external('MakeOperatorsC', 'MAPLE', 'LIB'=lib_path);
	BuildFramesAutoC := define_external('BuildFramesAutoC', 'MAPLE', 'LIB'=lib_path);
	AddSecondaryC := define_external('AddSecondaryC', 'LIB'=lib_path, address::string, weight::float[4]);
	ClearSecondariesC := define_external('ClearSecondariesC', 'LIB'=lib_path);
	ListSecondariesC := define_external('ListSecondariesC', 'MAPLE', 'LIB'=lib_path);
	SecondaryCountC := define_external('SecondaryCountC', 'LIB'=lib_path, 'RETURN'::integer[4]);

	return NULL;
end; # function ModuleLoad


ModuleLoad();


# attempt to convert input to a float[8] vector (will fail with any non-numeric entries).  if input is already a float vector,
# we just return it, without copying.  (NOTE: Maple doesn't seem to distinguish between float[4] and float[8] in type-checking.
# we're punting on this issue for right now...)
# inputs
#   thing: must be a numeric, list, vector, matrix, or array
#     * numeric: becomes a &lt;1 x 1&gt; float[8] vector
#     * matrix: 2-D matrix (more than 1 row and more than 1 column) raises an error
#     * array: 2 or more non-singleton dimensions raises an error.
# outputs
#   a float[8] vector
export Float8Vector := proc(thing)
	local num_rows, num_cols, dims, num_ns_dims;
	local call_stack;

	try
		if type(thing, 'Vector'(float)) and Dimension(thing) &gt; 0 then
			return thing;
		end;
	
		if type(thing, numeric) then
			return Vector([thing], datatype=float[8]);
		elif type(thing, Vector) or type(thing, list) then
			return Vector(thing, datatype=float[8]);
		elif type(thing, Matrix) then
			num_rows := RowDimension(thing);
			num_cols := ColumnDimension(thing);
			print(num_rows, num_cols);
			if num_rows = 0 or num_cols = 0 then
				return Vector(datatype=float[8]);
			elif num_rows = 1 then
				return Vector(thing[1, ..], datatype=float[8]);
			elif num_cols = 1 then
				return Vector(thing[.., 1], datatype=float[8]);
			else
				error; # can't convert 2-D matrix to vector
			end; # if/else (number of matrix rows/columns)
		elif type(thing, Array) then
			dims := Size(thing);
			if Dimension(dims) = 0 then
				return Vector(datatype=float[8]);
			end;
			num_ns_dims := nops(select(i -&gt; dims[i] &gt; 1, [$1..Dimension(dims)])); # number of non-singleton dimensions
			if num_ns_dims &lt;= 1 then
				if dims[2] &gt; 1 then
					return Vector[row](thing(..), datatype=float[8]);
				else
					return Vector[column](thing(..), datatype=float[8]);
				end;
			else
				error;
			end;
		end; # if/else (which main type)
	catch:
		call_stack := debugopts(callstack);
		error &quot;failed to convert %1 to float[8] vector (called from %2: \134&quot;%3\134&quot;)&quot;, whattype(thing), call_stack[5], call_stack[6];
	end; # try/catch
end; # function Float8Vector


# attempt to convert input to a float[8] matrix (will fail with any non-numeric entries).  if input is already a float matrix,
# we just return it, without copying.  (NOTE: Maple doesn't seem to distinguish between float[4] and float[8] in type-checking.
# we're punting on this issue for right now...)
# inputs
#   thing: must be a vector, matrix, or array.  conversion will fail (raising an error) if thing is
#     an array with any non-singleton dimensions in dimensions 3 and higher
# outputs
#   a float[8] matrix
export Float8Matrix := proc(thing)
	local dims, num_dims;
	local call_stack;

	try
		if not (type(thing, Vector) or type(thing, Matrix) or type(thing, Array)) then
			error;
		end;

		if type(thing, 'Matrix'(float)) and RowDimension(thing) &gt; 0 and ColumnDimension(thing) &gt; 0 then
			return thing;
		end;

		dims := Size(thing);
		num_dims := Dimension(dims);

		if num_dims = 0 then
			return Matrix(datatype=float[8]);
		elif num_dims &lt;= 2 then
			return Matrix(thing, datatype=float[8]);
		else
			if not (max(dims[3..-1]) = 1) then
				error; # dimensions 3 and up are not all singletons
			end;
			return Matrix(thing(1..dims[1], 1..dims[2]), datatype=float[8]);
		end;
	catch:
		call_stack := debugopts(callstack);
		error &quot;failed to convert %1 to float[8] matrix (called from %2: \134&quot;%3\134&quot;)&quot;, whattype(thing), call_stack[5], call_stack[6];
	end; # try/catch
end; # function Float8Matrix


# attempt to convert input to a 3-D float[8] array (will fail with any non-numeric entries).  if input is already a 3-D float array,
# we just return it, without copying.  (NOTE: Maple doesn't seem to distinguish between float[4] and float[8] in type-checking.
# we're punting on this issue for right now...)
# inputs
#   thing: must be a matrix, or array.  conversion will fail (raising an error) if thing is
#     an array with any non-singleton dimensions in dimensions 4 and higher
# outputs
#   a 3-D float[8] array
export Float8Array3D := proc(thing)
	local array_out, dims;
	local call_stack;

	try
		if type(thing, 'Array'(float)) and Dimension(Size(thing)) = 3 and min(Size(thing)) &gt; 0 then
			return thing;
		end;

		if type(thing, Matrix) then
			if RowDimension(thing) = 0 or ColumnDimension(thing) = 0 then
				return Array(0..0, 0..0, 0..0, datatype=float[8]);
			end;			
			array_out := convert(thing, Array)(.., .., ..);
			array_out := Array(array_out, datatype=float[8]);
			return array_out;
		elif type(thing, Array) then
			dims := Size(thing);
			if Dimension(dims) &gt; 3 and max(dims[4..-1]) &gt; 1 then
				error;
			end;
			if Dimension(dims) = 0 or min(dims) = 0 then
				return Array(0..0, 0..0, 0..0, datatype=float[8]);
			end;
			array_out := thing(.., .., ..);
			array_out := Array(array_out, datatype=float[8]);
			return array_out;
		else
			error;
		end;
	catch:
		call_stack := debugopts(callstack);
		error &quot;failed to convert %1 to 3-D float[8] array (called from %2: \134&quot;%3\134&quot;)&quot;, whattype(thing), call_stack[5], call_stack[6];
	end; # try/catch
end; # function Float8Array3D


# given a matrix, subtract the mean from each column and return the result.
# inputs
#   dat_in: anything convertible to a float matrix
#   col_means_in: if empty ([]), we use the column means from dat_in.  if not empty, should be a vector of column means,
#     which we then use.  (this option is needed for running out-of-sample points through a DQC map.)  default [].
# outputs
#   dat: float8 matrix with centered columns.
#   col_means: vector of column means.  (col_means_in is simply passed back out if it was not empty.)
export CenterColumns := proc(dat_in::rtable, col_means_in:=[])
	local dat, num_cols, col_means, col_idx, col;

	dat := copy(Float8Matrix(dat_in)); # make a copy, since we change it below
	num_cols := ColumnDimension(dat);

	if col_means_in = [] then
		col_means := Vector[row](num_cols, datatype=float[8]);
	else
		if not type(col_means_in, Vector) then
			error &quot;'col_means_in' must be of type Vector, received %1&quot;, whattype(col_means_in);
		end;
		col_means := copy(col_means_in);
	end;
	if Dimension(col_means) &lt;&gt; num_cols then
		error &quot;size of 'col_means_in' must match number of columns in 'dat_in'&quot;;
	end;

	for col_idx from 1 to num_cols do
		col := dat[.., col_idx];
		if col_means_in = [] then
			col_means[col_idx] := Mean(col); # build column means as we go (if they weren't passed in)
		end;
		col := col -~ col_means[col_idx];
		dat[.., col_idx] := col;
	end do;

	return dat, col_means;
end; # function CenterColumns


# given a matrix, divide each row by its L2 norm and return the result.
# inputs
#   mat_in: anything convertible to a float matrix
# outputs
#   mat_out: matrix with L2-normalized rows
export L2NormalizeRows := proc(mat_in::rtable)
	local mat, num_rows, num_cols, matc, matc_out, mat_out;

	mat := Float8Matrix(mat_in);

	num_rows := Size(mat, 1);
	num_cols := Size(mat, 2);

	# note: L2NormRowsC is *not* Maple-aware, so we pass things in C (row-major) order
	matc := Matrix(mat, datatype=float[8], order=C_order);
	matc_out := Matrix(num_rows, num_cols, datatype=float[8], order=C_order);
	L2NormRowsC(matc, num_rows, num_cols, matc_out);

	mat_out := Matrix(matc_out, datatype=float[8], order=Fortran_order);
	return mat_out;
end; # function L2NormalizeRows


# same functionality as L2NormalizeRows, but all in Maple (for testing/debugging)
export L2NormalizeRowsMaple := proc(mat_in::rtable)
	local mat, row_norms, row_idx;

	mat := copy(Float8Matrix(mat_in));

	row_norms := GetRowNorms(mat):

	for row_idx from 1 to Size(mat, 1) do
		mat[row_idx, ..] := mat[row_idx, ..] /~ row_norms[row_idx];
	end; # for each row

	return mat;
end; # function L2NormalizeRowsMaple


# return vector of L2 norms for each row of dat (which must be convertible to a float8 matrix)
export GetRowNorms := proc(dat_in::rtable)
	local dat, num_rows, row_norms, row_idx;

	dat := Float8Matrix(dat_in);

	num_rows := Size(dat, 1);
	row_norms := Vector(num_rows, datatype=float[8]);
	for row_idx from 1 to num_rows do
		row_norms[row_idx] := Norm(dat[row_idx, ..], 2);
	end;

	return row_norms;
end; # function GetRowNorms


# given a vector of SVD singular values, display 3 plots:
#   * normalized singular values
#   * normalized eigenvalues
#   * proportional cumulative variance
# inputs
#   s_in: SVD singular values (any type convertible to a float vector)
#   num_dims_to_plot: how many dimensions to show in the plots.  default 0 (meaning, show all dimensions)
# outputs
#   (none)
export PlotSVD := proc(s_in::rtable, num_dims_to_plot::integer:=0)
	local s, n_dims, s_norm, eig_norm, cum_var, dim_nums, plot_settings, p1, p2, p3;

	s := Float8Vector(s_in);

	n_dims := Dimension(s);
	if num_dims_to_plot &gt; 0 and num_dims_to_plot &lt; n_dims then
		n_dims := num_dims_to_plot;
	end;

	s_norm := s /~ s[1]; # normalized singular values
	eig_norm := (s^~2) /~ (s[1]^2);  # normalized eigenvalues
	cum_var := Vector(CumulativeSum(eig_norm)) /~  AddAlongDimension(eig_norm); # proportional cumulative variance

	dim_nums := [$1..n_dims];
	plot_settings := [labeldirections=[horizontal, vertical], color=&quot;Blue&quot;, style=pointline];
	p1 := plot(dim_nums, s_norm[1..n_dims], title=&quot;SVD: Normalized Singular Values&quot;, labels=[&quot;dimension number&quot;, &quot;normalized singular value&quot;],
			op(plot_settings));
	p2 := plot(dim_nums, eig_norm[1..n_dims], title=&quot;SVD: Normalized Eigenvalues&quot;, labels=[&quot;dimension number&quot;, &quot;normalized eigenvalue&quot;],
			op(plot_settings));
	p3 := plot(dim_nums, cum_var[1..n_dims], title=&quot;SVD: Cumulative Variance&quot;, labels=[&quot;dimension number&quot;, &quot;cumulative variance&quot;],
			op(plot_settings));
	print(display(&lt;p1 | p2 | p3&gt;));

	return NULL;
end proc: # function PlotSVD


# drop any frames at the end where all points have stopped moving -- i.e., where frame n + 1 is
# identical to frame n.
#
# note: output will be a reference to the frames passed in if no frames were dropped
export PareFrames := proc(frames_in, verbose::boolean:=true)
	local frames, num_frames, frame_idx, frame_changed;

	frames := frames_in;

	num_frames := Size(frames, 3);

	if num_frames &lt;= 1 then
		return frames;
	end;

	# walk backward until we find a pair of consecutive frames that are not identical
	for frame_idx from num_frames to 2 by -1 do
		frame_changed := evalb(not verify(frames[.., .., frame_idx], frames[.., .., frame_idx - 1], Array));
		if frame_changed then
			break;
		end
	end; # for each comparison frame

	if not frame_changed then
		if verbose then
			printf(&quot;WARNING: all frames are identical -- returning first frame\134n&quot;);
		end;
		frames := frames[.., .., 1..1]; # keep it 3-D
	else
		frames := frames[.., .., 1..frame_idx];
	end;

	return frames;
end; # method PareFrames


